---
import type { Story } from '../data/stories';

interface Props {
  story: Story;
}

const { story } = Astro.props;

const statusLabel = { ongoing: 'Ongoing', complete: 'Complete', hiatus: 'On Hiatus' }[story.status];
const statusClass = { ongoing: 'status-ongoing', complete: 'status-complete', hiatus: 'status-hiatus' }[story.status];
---

<article class="group flex flex-col sm:flex-row gap-6 bg-white dark:bg-sand-900 rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow border border-sand-100 dark:border-sand-800">
  <!-- Cover -->
  <a href={`/story/${story.id}`} class="sm:w-48 sm:shrink-0 block overflow-hidden">
    <img
      src={story.coverImage}
      alt={`Cover image for ${story.title}`}
      class="w-full h-48 sm:h-full object-cover group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
      onerror="this.src='/images/placeholder-cover.jpg'"
    />
  </a>

  <!-- Content -->
  <div class="flex flex-col justify-between p-6 flex-1">
    <div>
      <div class="flex flex-wrap items-center gap-2 mb-3">
        <span class={`text-xs px-2.5 py-1 rounded-full font-medium ${statusClass}`}>{statusLabel}</span>
        {story.genre.map((g) => (
          <span class="text-xs text-sand-600 dark:text-sand-400 border border-sand-200 dark:border-sand-700 px-2 py-0.5 rounded-full">{g}</span>
        ))}
      </div>

      <h2 class="font-cormorant font-semibold text-2xl text-sand-900 dark:text-sand-50 mb-1" style="font-family: var(--font-cormorant);">
        <a href={`/story/${story.id}`} class="hover:text-sand-700 dark:hover:text-sand-200 transition-colors">{story.title}</a>
      </h2>
      <p class="text-sand-600 dark:text-sand-400 italic text-sm mb-3" style="font-family: var(--font-cormorant);">{story.subtitle}</p>
      <p class="text-sand-700 dark:text-sand-300 text-sm leading-relaxed line-clamp-3">{story.description}</p>
    </div>

    <div class="flex items-center justify-between mt-4">
      <span class="text-xs text-sand-400">{story.chapters.length} {story.chapters.length === 1 ? 'chapter' : 'chapters'}</span>
      <a
        href={`/story/${story.id}`}
        class="text-sm text-sand-700 dark:text-sand-300 hover:text-sand-900 dark:hover:text-sand-50 font-medium transition-colors"
      >
        Start reading →
      </a>
    </div>
  </div>
</article>
