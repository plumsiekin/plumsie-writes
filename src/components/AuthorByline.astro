---
interface Props {
  size?: 'sm' | 'base';
}
const { size = 'base' } = Astro.props;
---

<div class={`author-byline ${size === 'sm' ? 'text-xs' : 'text-sm'}`}>
  <div class="author-avatar" aria-hidden="true">p</div>
  <div>
    <p class={`font-medium text-sand-900 dark:text-sand-100 ${size === 'sm' ? 'text-xs' : 'text-sm'}`}>plumsiepie</p>
    <p class="text-xs text-sand-600 dark:text-sand-400">SimLit writer. Malmö, Sweden.</p>
  </div>
</div>
