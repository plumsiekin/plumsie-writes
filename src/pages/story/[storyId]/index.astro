---
import Layout from '@/layouts/Layout.astro';
import Ornament from '@/components/Ornament.astro';
import ChapterList from '@/components/ChapterList.astro';
import ContentWarning from '@/components/ContentWarning.astro';
import { stories, type Character, type Story } from '@/data/stories';

export function getStaticPaths() {
  return stories.map((story) => ({
    params: { storyId: story.id },
    props: { story },
  }));
}

interface Props {
  story: Story;
}
const { story } = Astro.props;

const statusLabels = { ongoing: 'Ongoing', complete: 'Complete', hiatus: 'On Hiatus' } as const;
const statusClasses = { ongoing: 'status-ongoing', complete: 'status-complete', hiatus: 'status-hiatus' } as const;

const desc = story.description.length > 160 ? story.description.slice(0, 157) + '…' : story.description;
---

<Layout
  title={`${story.title} — SimLit by plumsiepie`}
  description={desc}
  ogImage={story.coverImage}
>
  <div class="-mt-20">
    <!-- Cover hero -->
    <section class="relative h-[70vh] min-h-[480px] flex items-end overflow-hidden">
      <div class="absolute inset-0 overflow-hidden">
        <img
          src={story.coverImage}
          alt={`Cover image for ${story.title}`}
          class="ken-burns w-full h-full object-cover"
          onerror="this.onerror=null;this.src='/images/placeholder-cover.jpg'"
        />
      </div>
      <div class="cover-gradient absolute inset-0 pointer-events-none"></div>
      <div class="absolute inset-0 pointer-events-none cover-gradient-side"></div>

      <div class="relative z-10 max-w-6xl mx-auto px-6 pb-12 w-full">
        <div class="max-w-xl">
          <div class="flex flex-wrap items-center gap-2 mb-4">
            <span class={`text-xs px-2.5 py-1 rounded-full font-medium ${statusClasses[story.status as Story['status']]}`}>
              {statusLabels[story.status as Story['status']]}
            </span>
            {story.genre.map((g) => (
              <span class="text-xs text-sand-300 border border-sand-600 px-2 py-0.5 rounded-full">{g}</span>
            ))}
          </div>
          <h1 class="font-cormorant font-semibold text-4xl md:text-6xl text-white mb-2 leading-tight">
            {story.title}
          </h1>
          <p class="text-sand-300 text-lg italic mb-6 font-cormorant">{story.subtitle}</p>
          <a
            href={`/story/${story.id}/chapter/1`}
            class="inline-block bg-sand-100 hover:bg-white text-sand-900 text-sm font-medium px-6 py-3 rounded transition-colors"
          >
            Start from Chapter 1
          </a>
        </div>
      </div>
    </section>

    <div class="max-w-4xl mx-auto px-6 py-16">
      <!-- Description -->
      <section class="max-w-2xl mb-12">
        <p class="text-sand-700 dark:text-sand-300 text-lg leading-relaxed">{story.description}</p>
      </section>

      <Ornament />

      {story.contentWarnings.length > 0 && (
        <section class="mb-12">
          <ContentWarning warnings={story.contentWarnings} label="Story content warnings" />
        </section>
      )}

      <!-- Character preview -->
      <section class="mb-12">
        <div class="flex items-baseline justify-between mb-6">
          <h2 class="font-cormorant font-semibold text-2xl text-sand-900 dark:text-sand-50">Characters</h2>
          <a
            href={`/story/${story.id}/characters`}
            class="text-sm text-sand-600 hover:text-sand-700 dark:hover:text-sand-200 transition-colors"
          >
            Full cast →
          </a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {story.characters.slice(0, 4).map((char: Character) => (
            <div class="flex items-start gap-3 p-4 bg-sand-100 dark:bg-sand-900 rounded-lg">
              <div class="w-10 h-10 rounded-full bg-sand-300 dark:bg-sand-700 shrink-0 overflow-hidden">
                {char.portrait ? (
                  <img
                    src={char.portrait}
                    alt={char.name}
                    class="w-full h-full object-cover"
                    loading="lazy"
                    onerror="this.onerror=null;this.style.display='none'"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center text-sand-600 text-xs font-medium">
                    {char.name[0]}
                  </div>
                )}
              </div>
              <div>
                <p class="font-medium text-sand-900 dark:text-sand-100 text-sm">{char.name}</p>
                <p class="text-xs text-sand-600 dark:text-sand-400">{char.role}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <Ornament />

      <!-- Chapter list -->
      <section>
        <div class="flex items-baseline justify-between mb-6">
          <h2 class="font-cormorant font-semibold text-2xl text-sand-900 dark:text-sand-50">Chapters</h2>
          <a
            href={`/story/${story.id}/chapter/1`}
            class="text-sm text-sand-600 dark:text-sand-400 border border-sand-300 dark:border-sand-700 px-3 py-1 rounded hover:bg-sand-100 dark:hover:bg-sand-800 transition-colors"
          >
            New? Start at Chapter 1 →
          </a>
        </div>
        <ChapterList storyId={story.id} chapters={story.chapters} />
      </section>
    </div>
  </div>
</Layout>
