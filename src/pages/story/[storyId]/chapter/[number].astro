---
import Layout from '../../../../layouts/Layout.astro';
import Ornament from '../../../../components/Ornament.astro';
import ContentWarning from '../../../../components/ContentWarning.astro';
import ReadingProgress from '../../../../components/ReadingProgress.astro';
import ScrollProgressBar from '../../../../components/ScrollProgressBar.astro';
import RelatedContent from '../../../../components/RelatedContent.astro';
import { stories } from '../../../../data/stories';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  return stories.flatMap((story) =>
    story.chapters.map((ch) => ({
      params: { storyId: story.id, number: String(ch.number) },
    }))
  );
}

const { storyId, number } = Astro.params;
const story = stories.find((s) => s.id === storyId);
if (!story) return Astro.redirect('/stories');

const chapterNum = parseInt(number ?? '1', 10);
const chapter = story.chapters.find((c) => c.number === chapterNum);
if (!chapter) return Astro.redirect(`/story/${storyId}`);

const prevChapter = story.chapters.find((c) => c.number === chapterNum - 1);
const nextChapter = story.chapters.find((c) => c.number === chapterNum + 1);

const paragraphs = chapter.content.split('\n\n').filter(Boolean);

// Related: other chapters + blog posts
const blogPosts = await getCollection('blog');
const relatedItems = [
  // Next chapter if exists, otherwise another story
  nextChapter
    ? {
        href: `/story/${storyId}/chapter/${nextChapter.number}`,
        title: nextChapter.title,
        tag: story.title,
        excerpt: nextChapter.excerpt,
        readingTime: nextChapter.readingTime,
      }
    : {
        href: `/story/${storyId}`,
        title: story.title,
        tag: 'Story',
        excerpt: story.description,
      },
  // A blog post
  ...(blogPosts.length > 0
    ? [{
        href: `/blog/${blogPosts[0].id}`,
        title: blogPosts[0].data.title,
        tag: blogPosts[0].data.category.replace(/-/g, ' '),
        excerpt: blogPosts[0].data.excerpt,
      }]
    : []),
].slice(0, 2);

const chapterTitle = `Chapter ${chapter.number}: ${chapter.title}`;
const pageTitle = `${chapterTitle} — ${story.title} | plumsiepie`;
const pageDescription = chapter.excerpt.length > 160 ? chapter.excerpt.slice(0, 157) + '…' : chapter.excerpt;
---

<Layout
  title={pageTitle}
  description={pageDescription}
  ogImage={chapter.imageUrl ?? story.coverImage}
  ogType="article"
  fullWidthHero={!!chapter.imageUrl}
>
  <ScrollProgressBar slot="head" />

  {chapter.imageUrl && (
    <section class="relative h-[45vh] min-h-[280px] overflow-hidden flex items-end">
      <div class="absolute inset-0 overflow-hidden">
        <img
          src={chapter.imageUrl}
          alt={`Cover for ${chapter.title}`}
          class="ken-burns w-full h-full object-cover"
          onerror="this.style.display='none'"
        />
      </div>
      <div class="cover-gradient absolute inset-0 pointer-events-none"></div>
    </section>
  )}

  <div class={`max-w-3xl mx-auto px-6 ${chapter.imageUrl ? 'pt-10' : 'pt-16'} pb-24`}>
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-xs text-sand-400 dark:text-sand-600 mb-8" aria-label="Breadcrumb">
      <a href="/" class="hover:text-sand-700 dark:hover:text-sand-300 transition-colors">Home</a>
      <span aria-hidden="true">/</span>
      <a href={`/story/${story.id}`} class="hover:text-sand-700 dark:hover:text-sand-300 transition-colors">{story.title}</a>
      <span aria-hidden="true">/</span>
      <span class="text-sand-600 dark:text-sand-400">Ch. {chapter.number}</span>
    </nav>

    <!-- Chapter header -->
    <header class="mb-8">
      <p class="text-xs text-sand-400 dark:text-sand-600 uppercase tracking-widest mb-2">
        Chapter {String(chapter.number).padStart(2, '0')}
      </p>
      <h1
        class="font-cormorant font-semibold text-4xl md:text-5xl text-sand-900 dark:text-sand-50 mb-4 leading-tight"
        style="font-family: var(--font-cormorant);"
      >
        {chapter.title}
      </h1>

      <div class="flex flex-wrap items-center gap-4 text-xs text-sand-400 dark:text-sand-600 mb-4">
        <span>~{chapter.readingTime} min read</span>
        <span aria-hidden="true">·</span>
        <ReadingProgress current={chapter.number} total={story.chapters.length} />
      </div>

      <!-- Prev/Next top -->
      <div class="flex items-center justify-between text-sm text-sand-600 dark:text-sand-400 border-t border-sand-200 dark:border-sand-800 pt-4">
        {prevChapter ? (
          <a href={`/story/${storyId}/chapter/${prevChapter.number}`} class="hover:text-sand-800 dark:hover:text-sand-100 transition-colors truncate max-w-[45%]">
            ← {prevChapter.title}
          </a>
        ) : <span />}
        {nextChapter ? (
          <a href={`/story/${storyId}/chapter/${nextChapter.number}`} class="hover:text-sand-800 dark:hover:text-sand-100 transition-colors truncate max-w-[45%] text-right">
            {nextChapter.title} →
          </a>
        ) : <span />}
      </div>
    </header>

    <!-- Content warnings -->
    {chapter.contentWarnings.length > 0 && (
      <ContentWarning warnings={chapter.contentWarnings} collapsible={true} label="This chapter contains" />
    )}

    <!-- Prose -->
    <article class="prose-reader">
      {paragraphs.map((para) => (
        <p>{para}</p>
      ))}
    </article>

    <Ornament />

    <!-- Ko-fi callout -->
    <div class="bg-sand-100 dark:bg-sand-900 border border-sand-200 dark:border-sand-800 rounded-lg p-5 text-center mb-10">
      <p class="text-sand-600 dark:text-sand-400 text-sm mb-3">Enjoying the story? Support the writing.</p>
      <a
        href="https://ko-fi.com/plumsiepie"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block text-sm text-sand-700 dark:text-sand-300 border border-sand-300 dark:border-sand-600 px-4 py-2 rounded hover:bg-sand-200 dark:hover:bg-sand-800 transition-colors"
      >
        Buy me a coffee on Ko-fi ☕
      </a>
    </div>

    <!-- Prev/Next bottom -->
    <div class="flex items-center justify-between text-sm text-sand-600 dark:text-sand-400 border-t border-sand-200 dark:border-sand-800 pt-6 mb-6">
      {prevChapter ? (
        <a href={`/story/${storyId}/chapter/${prevChapter.number}`} class="hover:text-sand-800 dark:hover:text-sand-100 transition-colors truncate max-w-[45%]">
          ← {prevChapter.title}
        </a>
      ) : <span />}
      {nextChapter ? (
        <a href={`/story/${storyId}/chapter/${nextChapter.number}`} class="hover:text-sand-800 dark:hover:text-sand-100 transition-colors truncate max-w-[45%] text-right">
          {nextChapter.title} →
        </a>
      ) : (
        <a href={`/story/${storyId}`} class="hover:text-sand-800 dark:hover:text-sand-100 transition-colors">
          Back to {story.title} →
        </a>
      )}
    </div>

    <!-- Related content -->
    <RelatedContent items={relatedItems} />

    <!-- Comment placeholder -->
    <section class="border-t border-sand-200 dark:border-sand-800 pt-10 mt-10">
      <h2
        class="font-cormorant font-semibold text-2xl text-sand-900 dark:text-sand-50 mb-4"
        style="font-family: var(--font-cormorant);"
      >
        Thoughts
      </h2>
      <div class="bg-sand-100 dark:bg-sand-900 rounded-lg p-6 text-center text-sand-400 dark:text-sand-600 text-sm">
        Comments coming soon.
      </div>
    </section>
  </div>
</Layout>
