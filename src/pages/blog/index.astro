---
import Layout from '../../layouts/Layout.astro';
import Ornament from '../../components/Ornament.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const categoryLabels: Record<string, string> = {
  'sims-4': 'Sims 4',
  simlit: 'SimLit',
  'cc-mods': 'CC & Mods',
  gaming: 'Gaming',
  'behind-the-story': 'Behind the Story',
};

const categories = ['all', 'sims-4', 'simlit', 'cc-mods', 'gaming', 'behind-the-story'];
---

<Layout
  title="From the Simmer — Blog | plumsiepie"
  description="Writing about Sims 4, SimLit, CC & mods, and the behind-the-scenes of making game-inspired fiction. By plumsiepie."
>
  <div class="max-w-4xl mx-auto px-6 py-16">
    <div class="mb-4 text-center">
      <h1
        class="font-cormorant font-semibold text-5xl text-sand-900 dark:text-sand-50 mb-3"
        style="font-family: var(--font-cormorant);"
      >
        From the Simmer
      </h1>
      <p class="text-sand-600 dark:text-sand-400 text-sm mb-4">{posts.length} posts</p>
      <!-- Cross-link to stories -->
      <p class="text-sand-600 dark:text-sand-400 text-sm">
        Here for the fiction?
        <a href="/stories" class="text-sand-700 dark:text-sand-300 underline underline-offset-2 hover:text-sand-900 dark:hover:text-sand-100 transition-colors">
          Browse the stories →
        </a>
      </p>
    </div>

    <Ornament />

    <!-- Category filter (links to category pages + client-side filter) -->
    <div class="flex flex-wrap gap-2 mb-8" role="group" aria-label="Filter by category">
      {categories.map((cat) => (
        <button
          data-filter={cat}
          data-href={cat === 'all' ? '/blog' : `/blog/category/${cat}`}
          class={`filter-btn text-sm px-4 py-1.5 rounded-full border transition-colors ${
            cat === 'all'
              ? 'bg-sand-800 dark:bg-sand-700 text-sand-50 border-sand-800 dark:border-sand-700'
              : 'bg-transparent text-sand-600 dark:text-sand-400 border-sand-200 dark:border-sand-700 hover:border-sand-400 dark:hover:border-sand-500'
          }`}
        >
          {cat === 'all' ? 'All' : categoryLabels[cat]}
        </button>
      ))}
    </div>

    <!-- Posts grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6" id="posts-grid">
      {posts.map((post) => (
        <article
          data-category={post.data.category}
          class="post-item group bg-white dark:bg-sand-900 border border-sand-100 dark:border-sand-800 rounded-lg overflow-hidden hover:shadow-md transition-shadow"
        >
          <a href={`/blog/${post.id}`} class="block overflow-hidden aspect-video bg-sand-200 dark:bg-sand-800">
            <img
              src={post.data.coverImage}
              alt=""
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
              onerror="this.src='/images/placeholder-blog.jpg'"
            />
          </a>
          <div class="p-5">
            <div class="flex items-center gap-2 mb-3">
              <a
                href={`/blog/category/${post.data.category}`}
                class="text-xs text-sand-600 dark:text-sand-400 border border-sand-200 dark:border-sand-700 px-2 py-0.5 rounded-full hover:border-sand-400 transition-colors"
              >
                {categoryLabels[post.data.category] ?? post.data.category}
              </a>
              <time class="text-xs text-sand-400 dark:text-sand-600" datetime={post.data.date}>
                {new Date(post.data.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
              </time>
            </div>
            <h2
              class="font-cormorant font-semibold text-xl text-sand-900 dark:text-sand-50 mb-2 leading-snug group-hover:text-sand-700 dark:group-hover:text-sand-200 transition-colors"
              style="font-family: var(--font-cormorant);"
            >
              <a href={`/blog/${post.id}`}>{post.data.title}</a>
            </h2>
            <p class="text-sm text-sand-600 dark:text-sand-400 line-clamp-3">{post.data.excerpt}</p>
          </div>
        </article>
      ))}
    </div>

    <div id="no-results" class="hidden text-center text-sand-400 dark:text-sand-600 py-12 text-sm">
      No posts in this category yet.
    </div>
  </div>
</Layout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items = document.querySelectorAll<HTMLElement>('.post-item');
  const noResults = document.getElementById('no-results')!;

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;

      buttons.forEach((b) => {
        b.classList.remove('bg-sand-800', 'dark:bg-sand-700', 'text-sand-50', 'border-sand-800', 'dark:border-sand-700');
        b.classList.add('bg-transparent', 'text-sand-600', 'dark:text-sand-400', 'border-sand-200', 'dark:border-sand-700');
      });
      btn.classList.add('bg-sand-800', 'dark:bg-sand-700', 'text-sand-50', 'border-sand-800', 'dark:border-sand-700');
      btn.classList.remove('bg-transparent', 'text-sand-600', 'dark:text-sand-400', 'border-sand-200', 'dark:border-sand-700');

      let visible = 0;
      items.forEach((item) => {
        const show = filter === 'all' || item.dataset.category === filter;
        item.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      noResults.classList.toggle('hidden', visible > 0);
    });
  });
</script>
