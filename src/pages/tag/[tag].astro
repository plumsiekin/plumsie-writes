---
import Layout from '../../layouts/Layout.astro';
import StoryCard from '../../components/StoryCard.astro';
import Ornament from '../../components/Ornament.astro';
import { getCollection } from 'astro:content';
import { stories } from '../../data/stories';

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  const storyTags = stories.flatMap((s) => [...s.genre.map((g) => g.toLowerCase()), ...s.contentWarnings]);
  const blogTags = posts.flatMap((p) => [p.data.category]);
  const allTags = [...new Set([...storyTags, ...blogTags])];

  return allTags.map((tag) => ({ params: { tag } }));
}

const { tag } = Astro.params;
const posts = await getCollection('blog');

const matchedStories = stories.filter(
  (s) =>
    s.genre.map((g) => g.toLowerCase()).includes(tag ?? '') ||
    s.contentWarnings.includes(tag ?? '')
);

const matchedPosts = posts.filter((p) => p.data.category === tag);
---

<Layout
  title={`#${tag} — Plumsie's Place`}
  description={`Stories and posts tagged "${tag}" on Plumsie's Place.`}
>
  <div class="max-w-4xl mx-auto px-6 py-16">
    <div class="mb-10">
      <p class="text-xs text-sand-400 uppercase tracking-widest mb-2">Tag</p>
      <h1
        class="font-cormorant font-semibold text-4xl text-sand-900 dark:text-sand-50"
        style="font-family: var(--font-cormorant);"
      >
        #{tag}
      </h1>
    </div>

    {matchedStories.length > 0 && (
      <>
        <h2 class="text-xs uppercase tracking-widest text-sand-400 mb-4">Stories</h2>
        <div class="space-y-6 mb-12">
          {matchedStories.map((story) => <StoryCard story={story} />)}
        </div>
      </>
    )}

    {matchedPosts.length > 0 && (
      <>
        <Ornament />
        <h2 class="text-xs uppercase tracking-widest text-sand-400 mb-4">Blog posts</h2>
        <div class="space-y-4">
          {matchedPosts.map((post) => (
            <article class="flex gap-4 items-start p-4 bg-white dark:bg-sand-900 rounded-lg border border-sand-100 dark:border-sand-800">
              <div class="flex-1">
                <h3
                  class="font-cormorant font-semibold text-xl text-sand-900 dark:text-sand-50 mb-1"
                  style="font-family: var(--font-cormorant);"
                >
                  <a href={`/blog/${post.id}`} class="hover:text-sand-700 dark:hover:text-sand-200 transition-colors">
                    {post.data.title}
                  </a>
                </h3>
                <p class="text-sm text-sand-600 dark:text-sand-400">{post.data.excerpt}</p>
              </div>
            </article>
          ))}
        </div>
      </>
    )}

    {matchedStories.length === 0 && matchedPosts.length === 0 && (
      <p class="text-sand-400 dark:text-sand-600 text-sm">Nothing tagged "{tag}" yet.</p>
    )}
  </div>
</Layout>
