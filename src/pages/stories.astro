---
import Layout from '../layouts/Layout.astro';
import StoryCard from '../components/StoryCard.astro';
import Ornament from '../components/Ornament.astro';
import { stories } from '../data/stories';
---

<Layout
  title="The Library — Plumsie's Place"
  description="All stories by plumsiepie. Browse SimLit fiction in chapters — literary, melancholy-romantic, and game-inspired."
>
  <div class="max-w-4xl mx-auto px-6 py-16">
    <div class="mb-12 text-center">
      <h1
        class="font-cormorant font-semibold text-5xl text-sand-900 dark:text-sand-50 mb-3"
        style="font-family: var(--font-cormorant);"
      >
        The Library
      </h1>
      <p class="text-sand-600 dark:text-sand-400 text-sm mb-3">
        {stories.length} {stories.length === 1 ? 'story' : 'stories'}
      </p>
      <p class="text-sand-600 dark:text-sand-400 text-sm">
        Looking for writing tips and behind-the-scenes posts?
        <a href="/blog" class="text-sand-700 dark:text-sand-300 underline underline-offset-2 hover:text-sand-900 dark:hover:text-sand-100 transition-colors">
          Visit the blog →
        </a>
      </p>
    </div>

    <Ornament />

    <!-- Filter -->
    <div class="flex flex-wrap gap-2 mb-8" id="filter-buttons" role="group" aria-label="Filter by status">
      {['all', 'ongoing', 'complete', 'hiatus'].map((f) => (
        <button
          data-filter={f}
          class={`filter-btn text-sm px-4 py-1.5 rounded-full border transition-colors ${
            f === 'all'
              ? 'bg-sand-800 dark:bg-sand-600 text-sand-50 border-sand-800 dark:border-sand-600'
              : 'bg-transparent text-sand-600 dark:text-sand-400 border-sand-300 dark:border-sand-700 hover:border-sand-500 dark:hover:border-sand-500'
          }`}
        >
          {f === 'all' ? 'All' : f === 'hiatus' ? 'On Hiatus' : f.charAt(0).toUpperCase() + f.slice(1)}
        </button>
      ))}
    </div>

    <!-- Story list -->
    <div class="space-y-6" id="story-list">
      {stories.map((story) => (
        <div data-status={story.status} class="story-item">
          <StoryCard story={story} />
        </div>
      ))}
    </div>

    <div id="no-results" class="hidden text-center text-sand-400 dark:text-sand-600 py-12 text-sm">
      No stories in this category yet.
    </div>
  </div>
</Layout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items = document.querySelectorAll<HTMLElement>('.story-item');
  const noResults = document.getElementById('no-results')!;

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;

      buttons.forEach((b) => {
        b.classList.remove('bg-sand-800', 'dark:bg-sand-600', 'text-sand-50', 'border-sand-800', 'dark:border-sand-600');
        b.classList.add('bg-transparent', 'text-sand-600', 'dark:text-sand-400', 'border-sand-300', 'dark:border-sand-700');
      });
      btn.classList.add('bg-sand-800', 'dark:bg-sand-600', 'text-sand-50', 'border-sand-800', 'dark:border-sand-600');
      btn.classList.remove('bg-transparent', 'text-sand-600', 'dark:text-sand-400', 'border-sand-300', 'dark:border-sand-700');

      let visible = 0;
      items.forEach((item) => {
        const show = filter === 'all' || item.dataset.status === filter;
        item.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      noResults.classList.toggle('hidden', visible > 0);
    });
  });
</script>
