---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page not found — Plumsie's Place">
  <div class="min-h-[60vh] flex items-center justify-center px-6">
    <div class="max-w-md text-center">
      <h1 class="font-cormorant text-7xl text-sand-900 dark:text-sand-50">404</h1>
      <h2 class="mt-4 text-xl font-medium text-sand-800 dark:text-sand-100">Page not found</h2>
      <p class="mt-2 text-sm text-sand-600 dark:text-sand-400">
        The page you're looking for doesn't exist.
      </p>
      <div class="mt-6">
        <a
          href="/"
          class="inline-flex items-center justify-center rounded bg-sand-800 dark:bg-sand-700 px-4 py-2 text-sm font-medium text-sand-50 transition-colors hover:bg-sand-700"
        >
          Go home
        </a>
      </div>
    </div>
  </div>
</Layout>
